          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_5136" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAddress_WR1" name="WR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_5137" name="WR1">
            <language>EXPRESS_WHERE</language>
            <body>(NOT(EXISTS(Purpose))) OR
((Purpose &lt;&gt; IfcAddressTypeEnum.USERDEFINED) OR
((Purpose = IfcAddressTypeEnum.USERDEFINED) AND
  EXISTS(SELF.UserDefinedPurpose)))</body>
          </specification>
        </ownedRule>
