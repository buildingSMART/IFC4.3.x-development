          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_5134" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAddress_UserDefinedPurpose" name="UserDefinedPurpose" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
