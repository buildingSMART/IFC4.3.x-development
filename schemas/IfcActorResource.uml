      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcActorRole" name="IfcActorRole">
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActorRole_Role" name="Role" isOrdered="false" type="en_IfcRoleEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_5124" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_5125" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActorRole_UserDefinedRole" name="UserDefinedRole" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_5126" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_5127" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcActorRole_Description" name="Description" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_5128" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_5129" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcActorRole_WR1" name="WR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_5130" name="WR1">
            <language>EXPRESS_WHERE</language>
            <body>(Role &lt;&gt; IfcRoleEnum.USERDEFINED) OR
((Role = IfcRoleEnum.USERDEFINED) AND
  EXISTS(SELF.UserDefinedRole))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcAddress" name="IfcAddress" isAbstract="true">
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAddress_Purpose" name="Purpose" isOrdered="false" type="en_IfcAddressTypeEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_5131" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_5132" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAddress_Description" name="Description" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcText"/>
