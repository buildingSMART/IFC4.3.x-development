        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDoorLiningProperties_LiningToPanelOffsetX" name="LiningToPanelOffsetX" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_19714" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_19715" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDoorLiningProperties_LiningToPanelOffsetY" name="LiningToPanelOffsetY" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_19716" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_19717" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR31" name="WR31">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_19718" name="WR31">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(LiningDepth) AND NOT(EXISTS(LiningThickness)))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR32" name="WR32">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_19719" name="WR32">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(ThresholdDepth) AND NOT(EXISTS(ThresholdThickness)))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR33" name="WR33">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_19720" name="WR33">
            <language>EXPRESS_WHERE</language>
            <body>(EXISTS(TransomOffset) AND EXISTS(TransomThickness)) XOR
(NOT(EXISTS(TransomOffset)) AND NOT(EXISTS(TransomThickness)))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR34" name="WR34">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_19721" name="WR34">
            <language>EXPRESS_WHERE</language>
            <body>(EXISTS(CasingDepth) AND EXISTS(CasingThickness)) XOR
(NOT(EXISTS(CasingDepth)) AND NOT(EXISTS(CasingThickness)))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDoorLiningProperties_WR35" name="WR35">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_19722" name="WR35">
            <language>EXPRESS_WHERE</language>
            <body>(EXISTS(SELF\IfcPropertySetDefinition.DefinesType[1])) 
AND 
('IFC4X3_ADD2.IFCDOORTYPE' IN TYPEOF(SELF\IfcPropertySetDefinition.DefinesType[1]))</body>
          </specification>
        </ownedRule>
      </packagedElement>
