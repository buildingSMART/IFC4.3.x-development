        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBooleanResult_SecondOperand" name="SecondOperand" isOrdered="false" association="as_IfcBooleanResult_SecondOperand" type="un_IfcBooleanOperand">
