          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3916" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolid_DirectrixBounded" name="DirectrixBounded">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3917" name="DirectrixBounded">
            <language>EXPRESS_WHERE</language>
            <body>(EXISTS(StartParam) AND EXISTS(EndParam)) OR 
(SIZEOF(['IFC4X3_ADD2.IFCCONIC', 'IFC4X3_ADD2.IFCBOUNDEDCURVE'] * TYPEOF(Directrix)) = 1)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolid_DirectrixDim" name="DirectrixDim">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3918" name="DirectrixDim">
            <language>EXPRESS_WHERE</language>
            <body>Directrix.Dim = 3</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolid_InnerRadiusSize" name="InnerRadiusSize">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3919" name="InnerRadiusSize">
            <language>EXPRESS_WHERE</language>
            <body>(NOT EXISTS(InnerRadius)) OR (Radius &gt; InnerRadius)</body>
          </specification>
        </ownedRule>
      </packagedElement>
