          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3927" name="HasAdvancedFaces">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(Afs &lt;* SELF\IfcManifoldSolidBrep.Outer.CfsFaces |
