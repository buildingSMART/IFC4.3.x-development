          <general xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcSurface"/>
        </generalization>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSurface_Directrix" name="Directrix" isOrdered="false" association="as_IfcSectionedSurface_Directrix">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3886" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3887" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSurface_CrossSectionPositions" name="CrossSectionPositions_L[2:?]" isOrdered="false" association="as_IfcSectionedSurface_CrossSectionPositions">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis2PlacementLinear"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3888" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3889" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSurface_CrossSections" name="CrossSections_L[2:?]" isOrdered="false" association="as_IfcSectionedSurface_CrossSections">
          <type xmi:type="uml:Class" href="IfcProfileResource.uml#cl_IfcProfileDef"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3890" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3891" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_AreaProfileTypes" name="AreaProfileTypes">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3892" name="AreaProfileTypes">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* CrossSections | temp.ProfileType = IfcProfileTypeEnum.CURVE)) &lt;&gt; 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3893" name="CorrespondingSectionPositions">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(CrossSections) = SIZEOF(CrossSectionPositions)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_DirectrixIs3D" name="DirectrixIs3D">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3894" name="DirectrixIs3D">
            <language>EXPRESS_WHERE</language>
            <body>Directrix.Dim = 3</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_NoOffsets" name="NoOffsets">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3895" name="NoOffsets">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* CrossSectionPositions | EXISTS(temp.Location.OffsetLateral) OR EXISTS(temp.Location.OffsetVertical) OR EXISTS(temp.Location.OffsetLongitudinal))) = 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSurface_SectionsSameType" name="SectionsSameType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3896" name="SectionsSameType">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* CrossSections | TYPEOF(CrossSections[1]) :&lt;&gt;: TYPEOF(temp))) = 0</body>
          </specification>
        </ownedRule>
      </packagedElement>
