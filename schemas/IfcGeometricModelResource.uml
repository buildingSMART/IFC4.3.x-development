          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3945" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcExtrudedAreaSolid_ValidExtrusionDirection" name="ValidExtrusionDirection">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3946" name="ValidExtrusionDirection">
            <language>EXPRESS_WHERE</language>
            <body>IfcDotProduct(IfcRepresentationItem() || IfcGeometricRepresentationItem() || IfcDirection([0.0,0.0,1.0]), SELF.ExtrudedDirection) &lt;&gt; 0.0</body>
