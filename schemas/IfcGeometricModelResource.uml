          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3903" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3904" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptAreaSolid_SweptAreaType" name="SweptAreaType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3905" name="SweptAreaType">
            <language>EXPRESS_WHERE</language>
            <body>SweptArea.ProfileType = IfcProfileTypeEnum.Area</body>
          </specification>
        </ownedRule>
      </packagedElement>
