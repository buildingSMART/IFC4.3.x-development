        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSolidHorizontal_CrossSectionPositions" name="CrossSectionPositions_L[2:?]" isOrdered="false" association="as_IfcSectionedSolidHorizontal_CrossSectionPositions">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis2PlacementLinear"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3969" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3970" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolidHorizontal_CorrespondingSectionPositions" name="CorrespondingSectionPositions">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3971" name="CorrespondingSectionPositions">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(CrossSections) = SIZEOF(CrossSectionPositions)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolidHorizontal_NoLongitudinalOffsets" name="NoLongitudinalOffsets">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3972" name="NoLongitudinalOffsets">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* CrossSectionPositions | EXISTS(temp.Location.OffsetLongitudinal))) = 0</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSweptDiskSolidPolygonal" name="IfcSweptDiskSolidPolygonal">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_3973" general="cl_IfcSweptDiskSolid"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolidPolygonal_FilletRadius" name="FilletRadius?" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3974" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3975" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolidPolygonal_CorrectRadii" name="CorrectRadii">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3976" name="CorrectRadii">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(FilletRadius)) OR (FilletRadius &gt;= SELF\IfcSweptDiskSolid.Radius)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSweptDiskSolidPolygonal_DirectrixIsPolyline" name="DirectrixIsPolyline">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3977" name="DirectrixIsPolyline">
            <language>EXPRESS_WHERE</language>
            <body>('IFC4X3_ADD2.IFCPOLYLINE' IN TYPEOF(SELF\IfcSweptDiskSolid.Directrix)) OR
(('IFC4X3_ADD2.IFCINDEXEDPOLYCURVE' IN TYPEOF(SELF\IfcSweptDiskSolid.Directrix)) AND NOT(EXISTS(SELF\IfcSweptDiskSolid.Directrix\IfcIndexedPolyCurve.Segments)))</body>
          </specification>
        </ownedRule>
