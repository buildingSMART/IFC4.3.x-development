          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3738" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcBooleanResult_Dim" name="Dim" isOrdered="false" isDerived="true">
          <type xmi:type="uml:DataType" href="IfcGeometryResource.uml#dt_IfcDimensionCount"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3739" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3740" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_3741" name="Dim">
            <language>EXPRESS</language>
            <body>IfcDimensionCount := FirstOperand.Dim</body>
          </defaultValue>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanResult_FirstOperandClosed" name="FirstOperandClosed">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3742" name="FirstOperandClosed">
            <language>EXPRESS_WHERE</language>
            <body>NOT('IFC4X3_ADD2.IFCTESSELLATEDFACESET' IN TYPEOF(FirstOperand)) OR (EXISTS(FirstOperand.Closed) AND FirstOperand.Closed)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanResult_SameDim" name="SameDim">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3743" name="SameDim">
            <language>EXPRESS_WHERE</language>
            <body>FirstOperand.Dim = SecondOperand.Dim</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanResult_SecondOperandClosed" name="SecondOperandClosed">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3744" name="SecondOperandClosed">
            <language>EXPRESS_WHERE</language>
            <body>NOT('IFC4X3_ADD2.IFCTESSELLATEDFACESET' IN TYPEOF(SecondOperand)) OR (EXISTS(SecondOperand.Closed) AND SecondOperand.Closed)</body>
          </specification>
        </ownedRule>
