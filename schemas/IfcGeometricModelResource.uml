      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcBooleanClippingResult" name="IfcBooleanClippingResult">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_3819" general="cl_IfcBooleanResult"/>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanClippingResult_FirstOperandType" name="FirstOperandType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3820" name="FirstOperandType">
            <language>EXPRESS_WHERE</language>
            <body>('IFC4X3_ADD2.IFCSWEPTAREASOLID' IN TYPEOF(FirstOperand)) OR 
('IFC4X3_ADD2.IFCSWEPTDISCSOLID' IN TYPEOF(FirstOperand)) OR 
('IFC4X3_ADD2.IFCBOOLEANCLIPPINGRESULT' IN TYPEOF(FirstOperand))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanClippingResult_OperatorType" name="OperatorType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3821" name="OperatorType">
            <language>EXPRESS_WHERE</language>
            <body>Operator = DIFFERENCE</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanClippingResult_SecondOperandType" name="SecondOperandType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3822" name="SecondOperandType">
            <language>EXPRESS_WHERE</language>
            <body>('IFC4X3_ADD2.IFCHALFSPACESOLID' IN TYPEOF(SecondOperand))</body>
          </specification>
        </ownedRule>
      </packagedElement>
