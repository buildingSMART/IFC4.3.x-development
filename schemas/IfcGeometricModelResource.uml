          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3961" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3962" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRevolvedAreaSolid_AxisLine" name="AxisLine" isOrdered="false" isDerived="true">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcLine"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3963" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3964" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_3965" name="AxisLine">
            <language>EXPRESS</language>
            <body>IfcLine := IfcRepresentationItem() || IfcGeometricRepresentationItem () || IfcCurve() || IfcLine(Axis.Location, 
  IfcRepresentationItem() || IfcGeometricRepresentationItem () || IfcVector(Axis.Z,1.0))</body>
          </defaultValue>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRevolvedAreaSolid_AxisDirectionInXY" name="AxisDirectionInXY">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3966" name="AxisDirectionInXY">
            <language>EXPRESS_WHERE</language>
            <body>Axis.Z.DirectionRatios[3] = 0.0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRevolvedAreaSolid_AxisStartInXY" name="AxisStartInXY">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3967" name="AxisStartInXY">
            <language>EXPRESS_WHERE</language>
            <body>('IFC4X3_ADD2.IFCCARTESIANPOINT' IN TYPEOF(Axis.Location)) AND (Axis.Location\IfcCartesianPoint.Coordinates[3] = 0.0)</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSectionedSolidHorizontal" name="IfcSectionedSolidHorizontal">
