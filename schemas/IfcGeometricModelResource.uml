          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3911" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3912" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_StartParam" name="StartParam?" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcParameterValue"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3913" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3914" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSweptDiskSolid_EndParam" name="EndParam?" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcParameterValue"/>
