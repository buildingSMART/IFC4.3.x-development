          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3878" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3879" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSectionedSolid_CrossSections" name="CrossSections_L[2:?]" isOrdered="false" association="as_IfcSectionedSolid_CrossSections">
          <type xmi:type="uml:Class" href="IfcProfileResource.uml#cl_IfcProfileDef"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_3880" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_3881" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolid_ConsistentProfileTypes" name="ConsistentProfileTypes">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3882" name="ConsistentProfileTypes">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* CrossSections | CrossSections[1].ProfileType &lt;&gt; temp.ProfileType)) = 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolid_DirectrixIs3D" name="DirectrixIs3D">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3883" name="DirectrixIs3D">
            <language>EXPRESS_WHERE</language>
            <body>Directrix.Dim = 3</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSectionedSolid_SectionsSameType" name="SectionsSameType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3884" name="SectionsSameType">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* CrossSections | TYPEOF(CrossSections[1]) :&lt;&gt;: TYPEOF(temp))) = 0</body>
          </specification>
        </ownedRule>
      </packagedElement>
