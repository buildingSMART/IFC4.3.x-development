        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPolynomialCurve_CoefficientsX" name="CoefficientsX_L[2:?]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1344" value="0"/>
