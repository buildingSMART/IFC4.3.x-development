        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeCurve_CurveContinuous" name="CurveContinuous">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1458" name="CurveContinuous">
            <language>EXPRESS_WHERE</language>
            <body>((NOT ClosedCurve) AND (SIZEOF(QUERY(Temp &lt;* Segments | Temp.Transition = Discontinuous)) = 1)) OR ((ClosedCurve) AND (SIZEOF(QUERY(Temp &lt;* Segments | Temp.Transition = Discontinuous)) = 0))</body>
          </specification>
        </ownedRule>
