          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1452" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1453" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_1454" name="NSegments">
            <language>EXPRESS</language>
            <body>IfcInteger := SIZEOF(Segments)</body>
          </defaultValue>
