        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCartesianTransformationOperator_Dim" name="Dim" isOrdered="false" isDerived="true" type="dt_IfcDimensionCount">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1175" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1176" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_1177" name="Dim">
