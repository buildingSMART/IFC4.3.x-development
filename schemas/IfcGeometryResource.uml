          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1534" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRectangularTrimmedSurface_Vsense" name="Vsense" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1535" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1536" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangularTrimmedSurface_U1AndU2Different" name="U1AndU2Different">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1537" name="U1AndU2Different">
            <language>EXPRESS_WHERE</language>
            <body>U1 &lt;&gt; U2</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangularTrimmedSurface_UsenseCompatible" name="UsenseCompatible">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1538" name="UsenseCompatible">
            <language>EXPRESS_WHERE</language>
            <body>(('IFC4X3_ADD2.IFCELEMENTARYSURFACE' IN TYPEOF(BasisSurface)) AND
         (NOT ('IFC4X3_ADD2.IFCPLANE' IN TYPEOF(BasisSurface)))) OR
         ('IFC4X3_ADD2.IFCSURFACEOFREVOLUTION' IN TYPEOF(BasisSurface)) OR
         (Usense = (U2 &gt; U1))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangularTrimmedSurface_V1AndV2Different" name="V1AndV2Different">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1539" name="V1AndV2Different">
            <language>EXPRESS_WHERE</language>
            <body>V1 &lt;&gt; V2</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRectangularTrimmedSurface_VsenseCompatible" name="VsenseCompatible">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1540" name="VsenseCompatible">
            <language>EXPRESS_WHERE</language>
            <body>Vsense = (V2 &gt; V1)</body>
          </specification>
        </ownedRule>
      </packagedElement>
