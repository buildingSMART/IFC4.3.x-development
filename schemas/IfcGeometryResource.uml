          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1456" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_1457" name="ClosedCurve">
            <language>EXPRESS</language>
            <body>IfcLogical := Segments[NSegments].Transition &lt;&gt; Discontinuous</body>
          </defaultValue>
