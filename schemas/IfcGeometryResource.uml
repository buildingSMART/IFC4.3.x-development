        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPolynomialCurve_CorrectPositionDim" name="CorrectPositionDim">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1350" name="CorrectPositionDim">
            <language>EXPRESS_WHERE</language>
            <body>((Position.Dim=2) AND (NOT EXISTS(CoefficientsZ))) OR (Position.Dim=3)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPolynomialCurve_ValidCoefficients" name="ValidCoefficients">
