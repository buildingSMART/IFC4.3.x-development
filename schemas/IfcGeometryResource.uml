          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1459" name="SameDim">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF( QUERY( Temp &lt;* Segments | Temp.Dim &lt;&gt; Segments[1].Dim)) = 0</body>
          </specification>
        </ownedRule>
