            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(SELF\IfcContext.RepresentationContexts)) OR
(SIZEOF(QUERY(Temp &lt;* SELF\IfcContext.RepresentationContexts |
 'IFC4X3_ADD2.IFCGEOMETRICREPRESENTATIONSUBCONTEXT' IN TYPEOF(Temp)
