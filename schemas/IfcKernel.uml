        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProduct_ObjectPlacement" name="ObjectPlacement" isOrdered="false" association="as_IfcProduct_ObjectPlacement">
          <type xmi:type="uml:Class" href="IfcGeometricConstraintResource.uml#cl_IfcObjectPlacement"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_4192" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_4193" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProduct_Representation" name="Representation" isOrdered="false" association="as_IfcProduct_Representation">
          <type xmi:type="uml:Class" href="IfcRepresentationResource.uml#cl_IfcProductRepresentation"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_4194" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_4195" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcProduct_PlacementForShapeRepresentation" name="PlacementForShapeRepresentation">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_4196" name="PlacementForShapeRepresentation">
            <language>EXPRESS_WHERE</language>
            <body>(EXISTS(Representation) AND EXISTS(ObjectPlacement))
            OR (EXISTS(Representation) AND 
      (SIZEOF(QUERY(temp &lt;* Representation.Representations | 'IFC4X3_ADD2.IFCSHAPEREPRESENTATION' IN TYPEOF(temp))) = 0))
            OR (NOT(EXISTS(Representation)))</body>
          </specification>
        </ownedRule>
