      <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcMlsTotalThickness" name="IfcMlsTotalThickness">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_3195" name="IfcMlsTotalThickness">
          <language>EXPRESS_FUNCTION</language>
          <body>FUNCTION IfcMlsTotalThickness
(LayerSet : IfcMaterialLayerSet) : IfcLengthMeasure;
  LOCAL
    Max : IfcLengthMeasure := LayerSet.MaterialLayers[1].LayerThickness;    
  END_LOCAL;

  IF SIZEOF(LayerSet.MaterialLayers) &gt; 1 THEN
    REPEAT i := 2 TO HIINDEX(LayerSet.MaterialLayers);
       Max := Max + LayerSet.MaterialLayers[i].LayerThickness;
    END_REPEAT;
  END_IF;
  RETURN (Max);

END_FUNCTION;
</body>
        </specification>
      </packagedElement>
