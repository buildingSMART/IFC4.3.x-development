      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcAngularVelocityMeasure" name="IfcAngularVelocityMeasure">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2151">
