      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcAreaDensityMeasure" name="IfcAreaDensityMeasure">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2152">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_real"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcAreaMeasure" name="IfcAreaMeasure">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2153">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_real"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcBinary" name="IfcBinary">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2154">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_binary"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcBoolean" name="IfcBoolean">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2155">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_boolean"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcComplexNumber" name="IfcComplexNumber_A[1:2]">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2156">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_real"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcCompoundPlaneAngleMeasure" name="IfcCompoundPlaneAngleMeasure_L[3:4]">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2157">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_integer"/>
        </generalization>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_MinutesInRange" name="MinutesInRange">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2158" name="MinutesInRange">
            <language>EXPRESS_WHERE</language>
            <body>ABS(SELF[2]) &lt; 60</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_SecondsInRange" name="SecondsInRange">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2159" name="SecondsInRange">
            <language>EXPRESS_WHERE</language>
            <body>ABS(SELF[3]) &lt; 60</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_MicrosecondsInRange" name="MicrosecondsInRange">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2160" name="MicrosecondsInRange">
            <language>EXPRESS_WHERE</language>
            <body>(SIZEOF(SELF) = 3) OR (ABS(SELF[4]) &lt; 1000000)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_ConsistentSign" name="ConsistentSign">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2161" name="ConsistentSign">
            <language>EXPRESS_WHERE</language>
            <body>((SELF[1] &gt;= 0) AND (SELF[2] &gt;= 0) AND (SELF[3] &gt;= 0) AND ((SIZEOF(SELF) = 3) OR (SELF[4] &gt;= 0)))
OR
((SELF[1] &lt;= 0) AND (SELF[2] &lt;= 0) AND (SELF[3] &lt;= 0) AND ((SIZEOF(SELF) = 3) OR (SELF[4] &lt;= 0)))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcContextDependentMeasure" name="IfcContextDependentMeasure">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2162">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_real"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcCountMeasure" name="IfcCountMeasure">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2163">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_integer"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcCurvatureMeasure" name="IfcCurvatureMeasure">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2164">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_real"/>
        </generalization>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDerivedUnit" name="IfcDerivedUnit">
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedUnit_Elements" name="Elements_S[1:?]" isOrdered="false" association="as_IfcDerivedUnit_Elements" type="cl_IfcDerivedUnitElement">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2165" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2166" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedUnit_UnitType" name="UnitType" isOrdered="false" type="en_IfcDerivedUnitEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2167" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2168" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedUnit_UserDefinedType" name="UserDefinedType" isOrdered="false" type="dt_IfcLabel">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2169" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2170" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedUnit_Name" name="Name" isOrdered="false" type="dt_IfcLabel">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2171" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2172" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedUnit_Dimensions" name="Dimensions" isOrdered="false" isDerived="true" type="cl_IfcDimensionalExponents">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2173" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2174" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_2175" name="Dimensions">
            <language>EXPRESS</language>
            <body>IfcDimensionalExponents := IfcDeriveDimensionalExponents(Elements)</body>
          </defaultValue>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDerivedUnit_WR1" name="WR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2176" name="WR1">
            <language>EXPRESS_WHERE</language>
            <body>(SIZEOF (Elements) &gt; 1) OR ((SIZEOF (Elements) = 1) AND (Elements[1].Exponent &lt;&gt; 1 ))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDerivedUnit_WR2" name="WR2">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2177" name="WR2">
            <language>EXPRESS_WHERE</language>
            <body>(UnitType &lt;&gt; IfcDerivedUnitEnum.USERDEFINED) OR
((UnitType = IfcDerivedUnitEnum.USERDEFINED) AND 
 (EXISTS(SELF.UserDefinedType)))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDerivedUnitElement" name="IfcDerivedUnitElement">
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedUnitElement_Unit" name="Unit" isOrdered="false" association="as_IfcDerivedUnitElement_Unit" type="cl_IfcNamedUnit">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2178" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2179" value="1"/>
