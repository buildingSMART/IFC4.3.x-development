          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2637" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2638" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCurveStyle_ModelOrDraughting" name="ModelOrDraughting" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2639" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2640" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCurveStyle_IdentifiableCurveStyle" name="IdentifiableCurveStyle">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2641" name="IdentifiableCurveStyle">
            <language>EXPRESS_WHERE</language>
            <body>EXISTS(CurveFont) OR EXISTS(CurveWidth) OR EXISTS(CurveColour)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCurveStyle_MeasureOfWidth" name="MeasureOfWidth">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2642" name="MeasureOfWidth">
            <language>EXPRESS_WHERE</language>
            <body>(NOT(EXISTS(CurveWidth))) OR
('IFC4X3_ADD2.IFCPOSITIVELENGTHMEASURE' IN TYPEOF(CurveWidth)) OR 
 (('IFC4X3_ADD2.IFCDESCRIPTIVEMEASURE' IN TYPEOF(CurveWidth)) AND
 (CurveWidth = 'by layer'))</body>
          </specification>
        </ownedRule>
      </packagedElement>
