<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:version="20131001">
  <uml:Model xmi:id="md_IfcPresentationAppearanceResource" name="IfcPresentationAppearanceResource">
    <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcPresentationAppearanceResource" name="IfcPresentationAppearanceResource">
      <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcCorrectFillAreaStyle" name="IfcCorrectFillAreaStyle">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2588" name="IfcCorrectFillAreaStyle">
          <language>EXPRESS_FUNCTION</language>
          <body>FUNCTION IfcCorrectFillAreaStyle
  (Styles : SET[1:?] OF IfcFillStyleSelect)
  :LOGICAL;

LOCAL
   Hatching : INTEGER := 0;
   Tiles    : INTEGER := 0;
   Colour   : INTEGER := 0;
   External : INTEGER := 0;
END_LOCAL;


External := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCEXTERNALLYDEFINEDHATCHSTYLE' IN
   TYPEOF(Style)));

Hatching  := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCFILLAREASTYLEHATCHING' IN
   TYPEOF(Style)));

Tiles     := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCFILLAREASTYLETILES' IN
   TYPEOF(Style)));

Colour    := SIZEOF(QUERY(Style &lt;* Styles |
  'IFC4X3_ADD2.IFCCOLOUR' IN
   TYPEOF(Style)));


IF (External &gt; 1) THEN
  RETURN (FALSE);
END_IF;


IF ((External = 1) AND ((Hatching &gt; 0) OR (Tiles &gt; 0) OR (Colour &gt; 0))) THEN
  RETURN (FALSE);
END_IF;


IF (Colour &gt; 1) THEN
  RETURN (FALSE);
END_IF;

IF ((Hatching &gt; 0) AND (Tiles &gt;0)) THEN
  RETURN (FALSE);
END_IF;

RETURN(TRUE);

END_FUNCTION;
</body>
        </specification>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcFontStyle" name="IfcFontStyle">
