        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPixelTexture_ColourComponents" name="ColourComponents" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2825" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2826" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcPixelTexture_Pixel" name="Pixel_L[1:?]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBinary"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2827" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2828" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_MinPixelInS" name="MinPixelInS">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2829" name="MinPixelInS">
            <language>EXPRESS_WHERE</language>
            <body>Width &gt;= 1</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_MinPixelInT" name="MinPixelInT">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2830" name="MinPixelInT">
            <language>EXPRESS_WHERE</language>
            <body>Height &gt;= 1</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_NumberOfColours" name="NumberOfColours">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2831" name="NumberOfColours">
            <language>EXPRESS_WHERE</language>
            <body>{1 &lt;= ColourComponents &lt;= 4}</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_PixelAsByteAndSameLength" name="PixelAsByteAndSameLength">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2832" name="PixelAsByteAndSameLength">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp&lt;* Pixel |
 (BLENGTH(temp) MOD 8 = 0) AND
 (BLENGTH(temp) = BLENGTH(Pixel[1]))
)) = SIZEOF(Pixel)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPixelTexture_SizeOfPixelList" name="SizeOfPixelList">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2833" name="SizeOfPixelList">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(Pixel) = (Width * Height)</body>
          </specification>
        </ownedRule>
      </packagedElement>
