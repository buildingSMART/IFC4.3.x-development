      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcFillAreaStyle" name="IfcFillAreaStyle">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2664" general="cl_IfcPresentationStyle"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcFillAreaStyle_FillStyles" name="FillStyles_S[1:?]" isOrdered="false" association="as_IfcFillAreaStyle_FillStyles" type="un_IfcFillStyleSelect">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2665" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2666" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcFillAreaStyle_ModelOrDraughting" name="ModelOrDraughting" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2667" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2668" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFillAreaStyle_ConsistentHatchStyleDef" name="ConsistentHatchStyleDef">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2669" name="ConsistentHatchStyleDef">
            <language>EXPRESS_WHERE</language>
            <body>IfcCorrectFillAreaStyle(SELF.FillStyles)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFillAreaStyle_MaxOneColour" name="MaxOneColour">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2670" name="MaxOneColour">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(Style &lt;* SELF.FillStyles |
  'IFC4X3_ADD2.IFCCOLOUR' IN
   TYPEOF(Style)
  )) &lt;= 1</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcFillAreaStyle_MaxOneExtHatchStyle" name="MaxOneExtHatchStyle">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2671" name="MaxOneExtHatchStyle">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(Style &lt;* SELF.FillStyles |
  'IFC4X3_ADD2.IFCEXTERNALLYDEFINEDHATCHSTYLE' IN
   TYPEOF(Style)
  )) &lt;= 1</body>
