        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRelSpaceBoundary_RelatedBuildingElement" name="RelatedBuildingElement" isOrdered="false" association="as_IfcRelSpaceBoundary_RelatedBuildingElement" type="cl_IfcElement">
