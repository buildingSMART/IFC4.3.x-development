          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_10034" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSpatialStructureElement_WR41" name="WR41">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_10035" name="WR41">
            <language>EXPRESS_WHERE</language>
            <body>(HIINDEX(SELF\IfcObjectDefinition.Decomposes) = 1) 
AND
('IFC4X3_ADD2.IFCRELAGGREGATES' IN TYPEOF(SELF\IfcObjectDefinition.Decomposes[1])) 
AND
(('IFC4X3_ADD2.IFCPROJECT' IN TYPEOF (SELF\IfcObjectDefinition.Decomposes[1].RelatingObject)) OR
 ('IFC4X3_ADD2.IFCSPATIALSTRUCTUREELEMENT' IN TYPEOF (SELF\IfcObjectDefinition.Decomposes[1].RelatingObject))
)</body>
          </specification>
        </ownedRule>
      </packagedElement>
