      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSpatialStructureElement" name="IfcSpatialStructureElement" isAbstract="true">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_10032" general="cl_IfcSpatialElement"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSpatialStructureElement_CompositionType" name="CompositionType?" isOrdered="false" type="en_IfcElementCompositionEnum">
