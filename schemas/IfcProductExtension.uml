          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_9924" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRelSpaceBoundary_ConnectionGeometry" name="ConnectionGeometry?" isOrdered="false" association="as_IfcRelSpaceBoundary_ConnectionGeometry">
