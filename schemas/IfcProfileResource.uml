          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21991" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21992" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_WebThickness" name="WebThickness" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21993" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21994" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FlangeThickness" name="FlangeThickness" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21995" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21996" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FilletRadius" name="FilletRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21997" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21998" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FlangeEdgeRadius" name="FlangeEdgeRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21999" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_22000" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_FlangeSlope" name="FlangeSlope" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_22001" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_22002" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIShapeProfileDef_ValidFilletRadius" name="ValidFilletRadius">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_22003" name="ValidFilletRadius">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(FilletRadius)) OR
((FilletRadius &lt;= (OverallWidth - WebThickness)/2.) AND 
 (FilletRadius &lt;= (OverallDepth - (2. * FlangeThickness))/2.))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIShapeProfileDef_ValidFlangeThickness" name="ValidFlangeThickness">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_22004" name="ValidFlangeThickness">
            <language>EXPRESS_WHERE</language>
            <body>(2. * FlangeThickness) &lt; OverallDepth</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcIShapeProfileDef_ValidWebThickness" name="ValidWebThickness">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_22005" name="ValidWebThickness">
            <language>EXPRESS_WHERE</language>
            <body>WebThickness &lt; OverallWidth</body>
          </specification>
        </ownedRule>
      </packagedElement>
