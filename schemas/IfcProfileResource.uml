          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21990" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21991" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcIShapeProfileDef_OverallDepth" name="OverallDepth" isOrdered="false">
