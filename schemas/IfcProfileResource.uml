<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:version="20131001">
  <uml:Model xmi:id="md_IfcProfileResource" name="IfcProfileResource">
    <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcProfileResource" name="IfcProfileResource">
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcProfileDef" name="IfcProfileDef">
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProfileDef_ProfileType" name="ProfileType" isOrdered="false" type="en_IfcProfileTypeEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21866" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21867" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcProfileDef_ProfileName" name="ProfileName" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21868" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21869" value="1"/>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcProfileTypeEnum" name="IfcProfileTypeEnum">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21870" name="AREA"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21871" name="CURVE"/>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcReinforcingBarRoleEnum" name="IfcReinforcingBarRoleEnum">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21872" name="ANCHORING"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21873" name="EDGE"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21874" name="LIGATURE"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21875" name="MAIN"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21876" name="PUNCHING"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21877" name="RING"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21878" name="SHEAR"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21879" name="STUD"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21880" name="USERDEFINED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21881" name="NOTDEFINED"/>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcReinforcingBarSurfaceEnum" name="IfcReinforcingBarSurfaceEnum">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21882" name="PLAIN"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21883" name="TEXTURED"/>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcSectionTypeEnum" name="IfcSectionTypeEnum">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21884" name="TAPERED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_21885" name="UNIFORM"/>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcArbitraryClosedProfileDef" name="IfcArbitraryClosedProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21886" general="cl_IfcProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcArbitraryClosedProfileDef_OuterCurve" name="OuterCurve" isOrdered="false" association="as_IfcArbitraryClosedProfileDef_OuterCurve">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21887" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21888" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryClosedProfileDef_WR1" name="WR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21889" name="WR1">
            <language>EXPRESS_WHERE</language>
            <body>OuterCurve.Dim = 2</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryClosedProfileDef_WR2" name="WR2">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21890" name="WR2">
            <language>EXPRESS_WHERE</language>
            <body>NOT('IFC4X3_ADD2.IFCLINE' IN TYPEOF(OuterCurve))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryClosedProfileDef_WR3" name="WR3">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21891" name="WR3">
            <language>EXPRESS_WHERE</language>
            <body>NOT('IFC4X3_ADD2.IFCOFFSETCURVE2D' IN TYPEOF(OuterCurve))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcArbitraryOpenProfileDef" name="IfcArbitraryOpenProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21892" general="cl_IfcProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcArbitraryOpenProfileDef_Curve" name="Curve" isOrdered="false" association="as_IfcArbitraryOpenProfileDef_Curve">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcBoundedCurve"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21893" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21894" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryOpenProfileDef_WR11" name="WR11">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21895" name="WR11">
            <language>EXPRESS_WHERE</language>
            <body>('IFC4X3_ADD2.IFCCENTERLINEPROFILEDEF' IN TYPEOF(SELF)) OR 
 (SELF\IfcProfileDef.ProfileType = IfcProfileTypeEnum.CURVE)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryOpenProfileDef_WR12" name="WR12">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21896" name="WR12">
            <language>EXPRESS_WHERE</language>
            <body>Curve.Dim = 2</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCompositeProfileDef" name="IfcCompositeProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21897" general="cl_IfcProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeProfileDef_Profiles" name="Profiles_S[2:?]" isOrdered="false" association="as_IfcCompositeProfileDef_Profiles" type="cl_IfcProfileDef">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21898" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21899" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCompositeProfileDef_Label" name="Label" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21900" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21901" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeProfileDef_InvariantProfileType" name="InvariantProfileType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21902" name="InvariantProfileType">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* Profiles | temp.ProfileType &lt;&gt; Profiles[1].ProfileType)) = 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCompositeProfileDef_NoRecursion" name="NoRecursion">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21903" name="NoRecursion">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* Profiles | 'IFC4X3_ADD2.IFCCOMPOSITEPROFILEDEF' IN TYPEOF(temp))) = 0</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcDerivedProfileDef" name="IfcDerivedProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21904" general="cl_IfcProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedProfileDef_ParentProfile" name="ParentProfile" isOrdered="false" association="as_IfcDerivedProfileDef_ParentProfile" type="cl_IfcProfileDef">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21905" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21906" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedProfileDef_Operator" name="Operator" isOrdered="false" association="as_IfcDerivedProfileDef_Operator">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCartesianTransformationOperator2D"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21907" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21908" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcDerivedProfileDef_Label" name="Label" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21909" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21910" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcDerivedProfileDef_InvariantProfileType" name="InvariantProfileType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21911" name="InvariantProfileType">
            <language>EXPRESS_WHERE</language>
            <body>SELF\IfcProfileDef.ProfileType = ParentProfile.ProfileType</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcOpenCrossProfileDef" name="IfcOpenCrossProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21912" general="cl_IfcProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_HorizontalWidths" name="HorizontalWidths" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcBoolean"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21913" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21914" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_Widths" name="Widths_L[1:?]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21915" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21916" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_Slopes" name="Slopes_L[1:?]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21917" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21918" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_Tags" name="Tags_L[2:?]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21919" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21920" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOpenCrossProfileDef_OffsetPoint" name="OffsetPoint" isOrdered="false" association="as_IfcOpenCrossProfileDef_OffsetPoint">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCartesianPoint"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21921" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21922" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOpenCrossProfileDef_CorrectProfileType" name="CorrectProfileType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21923" name="CorrectProfileType">
            <language>EXPRESS_WHERE</language>
            <body>SELF\IfcProfileDef.ProfileType = IfcProfileTypeEnum.CURVE</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOpenCrossProfileDef_CorrespondingSlopeWidths" name="CorrespondingSlopeWidths">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21924" name="CorrespondingSlopeWidths">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(Slopes) = SIZEOF(Widths)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOpenCrossProfileDef_CorrespondingTags" name="CorrespondingTags">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21925" name="CorrespondingTags">
            <language>EXPRESS_WHERE</language>
            <body>(NOT EXISTS (Tags)) OR (SIZEOF(Tags) = (SIZEOF(Slopes) + 1))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcParameterizedProfileDef" name="IfcParameterizedProfileDef" isAbstract="true">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21926" general="cl_IfcProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcParameterizedProfileDef_Position" name="Position" isOrdered="false" association="as_IfcParameterizedProfileDef_Position">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcAxis2Placement2D"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21927" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21928" value="1"/>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcArbitraryProfileDefWithVoids" name="IfcArbitraryProfileDefWithVoids">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21929" general="cl_IfcArbitraryClosedProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcArbitraryProfileDefWithVoids_InnerCurves" name="InnerCurves_S[1:?]" isOrdered="false" association="as_IfcArbitraryProfileDefWithVoids_InnerCurves">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcCurve"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21930" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21931" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryProfileDefWithVoids_WR1" name="WR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21932" name="WR1">
            <language>EXPRESS_WHERE</language>
            <body>SELF\IfcProfileDef.ProfileType = AREA</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryProfileDefWithVoids_WR2" name="WR2">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21933" name="WR2">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* InnerCurves | temp.Dim &lt;&gt; 2)) = 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcArbitraryProfileDefWithVoids_WR3" name="WR3">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21934" name="WR3">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(temp &lt;* InnerCurves | 'IFC4X3_ADD2.IFCLINE' IN TYPEOF(temp))) = 0</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcAsymmetricIShapeProfileDef" name="IfcAsymmetricIShapeProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21935" general="cl_IfcParameterizedProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeWidth" name="BottomFlangeWidth" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21936" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21937" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_OverallDepth" name="OverallDepth" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21938" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21939" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_WebThickness" name="WebThickness" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21940" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21941" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeThickness" name="BottomFlangeThickness" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21942" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21943" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeFilletRadius" name="BottomFlangeFilletRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21944" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21945" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeWidth" name="TopFlangeWidth" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21946" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21947" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeThickness" name="TopFlangeThickness" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21948" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21949" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeFilletRadius" name="TopFlangeFilletRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21950" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21951" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeEdgeRadius" name="BottomFlangeEdgeRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21952" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21953" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_BottomFlangeSlope" name="BottomFlangeSlope" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21954" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21955" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeEdgeRadius" name="TopFlangeEdgeRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21956" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21957" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcAsymmetricIShapeProfileDef_TopFlangeSlope" name="TopFlangeSlope" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21958" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21959" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidBottomFilletRadius" name="ValidBottomFilletRadius">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21960" name="ValidBottomFilletRadius">
            <language>EXPRESS_WHERE</language>
            <body>(NOT(EXISTS(BottomFlangeFilletRadius))) OR 
(BottomFlangeFilletRadius &lt;= (BottomFlangeWidth - WebThickness)/2.)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidFlangeThickness" name="ValidFlangeThickness">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21961" name="ValidFlangeThickness">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(TopFlangeThickness)) OR ((BottomFlangeThickness + TopFlangeThickness) &lt; OverallDepth)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidTopFilletRadius" name="ValidTopFilletRadius">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21962" name="ValidTopFilletRadius">
            <language>EXPRESS_WHERE</language>
            <body>(NOT(EXISTS(TopFlangeFilletRadius))) OR 
(TopFlangeFilletRadius &lt;= (TopFlangeWidth - WebThickness)/2.)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcAsymmetricIShapeProfileDef_ValidWebThickness" name="ValidWebThickness">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21963" name="ValidWebThickness">
            <language>EXPRESS_WHERE</language>
            <body>(WebThickness &lt; BottomFlangeWidth) AND (WebThickness &lt; TopFlangeWidth)</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcCShapeProfileDef" name="IfcCShapeProfileDef">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_21964" general="cl_IfcParameterizedProfileDef"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCShapeProfileDef_Depth" name="Depth" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21965" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21966" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCShapeProfileDef_Width" name="Width" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21967" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21968" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCShapeProfileDef_WallThickness" name="WallThickness" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21969" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21970" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCShapeProfileDef_Girth" name="Girth" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPositiveLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21971" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21972" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcCShapeProfileDef_InternalFilletRadius" name="InternalFilletRadius" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcNonNegativeLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_21973" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_21974" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCShapeProfileDef_ValidGirth" name="ValidGirth">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21975" name="ValidGirth">
            <language>EXPRESS_WHERE</language>
            <body>Girth &lt; (Depth / 2.)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCShapeProfileDef_ValidInternalFilletRadius" name="ValidInternalFilletRadius">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21976" name="ValidInternalFilletRadius">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(InternalFilletRadius)) OR
((InternalFilletRadius &lt;= Width/2. - WallThickness) AND (InternalFilletRadius &lt;= Depth/2. - WallThickness))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCShapeProfileDef_ValidWallThickness" name="ValidWallThickness">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_21977" name="ValidWallThickness">
            <language>EXPRESS_WHERE</language>
            <body>(WallThickness &lt; Width/2.) AND (WallThickness &lt; Depth/2.)</body>
          </specification>
        </ownedRule>
      </packagedElement>
