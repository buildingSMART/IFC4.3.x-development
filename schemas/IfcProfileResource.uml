        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcLShapeProfileDef_ValidThickness" name="ValidThickness">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_22019" name="ValidThickness">
            <language>EXPRESS_WHERE</language>
            <body>(Thickness &lt; Depth) AND (NOT(EXISTS(Width)) OR (Thickness &lt; Width))</body>
          </specification>
        </ownedRule>
