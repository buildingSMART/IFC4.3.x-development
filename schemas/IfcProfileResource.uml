          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_22017" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcLShapeProfileDef_LegSlope" name="LegSlope" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcPlaneAngleMeasure"/>
