          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_18299" name="WR21">
            <language>EXPRESS_WHERE</language>
            <body>NOT(EXISTS(EnumerationReference)) 
OR  NOT(EXISTS(EnumerationValues)) 
OR  (SIZEOF(QUERY(temp &lt;* EnumerationValues |
    temp IN EnumerationReference.EnumerationValues))
    = SIZEOF(EnumerationValues))</body>
