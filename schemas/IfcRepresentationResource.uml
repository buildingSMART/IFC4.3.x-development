        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcCoordinateReferenceSystem_NameOrWKT" name="NameOrWKT">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1942" name="NameOrWKT">
            <language>EXPRESS_WHERE</language>
            <body>(HIINDEX(WellKnownText) = 1) OR EXISTS(Name)</body>
