        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRigidOperation_FirstCoordinate" name="FirstCoordinate" isOrdered="false" association="as_IfcRigidOperation_FirstCoordinate">
          <type xmi:type="uml:Class" href="IfcMeasureResource.uml#un_IfcMeasureValue"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2037" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2038" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRigidOperation_SecondCoordinate" name="SecondCoordinate" isOrdered="false" association="as_IfcRigidOperation_SecondCoordinate">
          <type xmi:type="uml:Class" href="IfcMeasureResource.uml#un_IfcMeasureValue"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2039" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2040" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcRigidOperation_Height" name="Height?" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2041" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2042" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRigidOperation_SameCoordinateType" name="SameCoordinateType">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2043" name="SameCoordinateType">
            <language>EXPRESS_WHERE</language>
            <body>(('IFC4X3_ADD2.IFCLENGTHMEASURE' IN TYPEOF(FirstCoordinate)) AND ('IFC4X3_ADD2.IFCLENGTHMEASURE' IN TYPEOF(SecondCoordinate))) OR (('IFC4X3_ADD2.IFCPLANEANGLEMEASURE' IN TYPEOF(FirstCoordinate)) AND ('IFC4X3_ADD2.IFCPLANEANGLEMEASURE' IN TYPEOF(SecondCoordinate)))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcShapeModel" name="IfcShapeModel" isAbstract="true">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_2044" general="cl_IfcRepresentation"/>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcShapeModel_WR11" name="WR11">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2045" name="WR11">
            <language>EXPRESS_WHERE</language>
            <body>(SIZEOF(SELF\IfcRepresentation.OfProductRepresentation) = 1) XOR 
(SIZEOF(SELF\IfcRepresentation.RepresentationMap) = 1) XOR
(SIZEOF(OfShapeAspect) = 1)</body>
          </specification>
        </ownedRule>
      </packagedElement>
