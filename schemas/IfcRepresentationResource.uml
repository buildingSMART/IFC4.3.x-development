          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2057" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_WorldCoordinateSystem" name="WorldCoordinateSystem" isOrdered="false" isDerived="true">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#un_IfcAxis2Placement"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2058" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2059" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_2060" name="WorldCoordinateSystem">
            <language>EXPRESS</language>
            <body>IfcAxis2Placement := ParentContext.WorldCoordinateSystem</body>
          </defaultValue>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_CoordinateSpaceDimension" name="CoordinateSpaceDimension" isOrdered="false" isDerived="true">
          <type xmi:type="uml:DataType" href="IfcGeometryResource.uml#dt_IfcDimensionCount"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2061" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2062" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_2063" name="CoordinateSpaceDimension">
            <language>EXPRESS</language>
            <body>IfcDimensionCount := ParentContext.CoordinateSpaceDimension</body>
          </defaultValue>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_TrueNorth" name="TrueNorth" isOrdered="false" isDerived="true">
          <type xmi:type="uml:Class" href="IfcGeometryResource.uml#cl_IfcDirection"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2064" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2065" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_2066" name="TrueNorth">
            <language>EXPRESS</language>
            <body>IfcDirection := NVL(ParentContext.TrueNorth, IfcConvertDirectionInto2D(SELF\IfcGeometricRepresentationContext.WorldCoordinateSystem.P[2]))</body>
          </defaultValue>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_Precision" name="Precision" isOrdered="false" isDerived="true">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcReal"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2067" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2068" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_2069" name="Precision">
            <language>EXPRESS</language>
            <body>IfcReal := NVL(ParentContext.Precision,1.E-5)</body>
          </defaultValue>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationSubContext_NoCoordOperation" name="NoCoordOperation">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2070" name="NoCoordOperation">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(SELF\IfcGeometricRepresentationContext.HasCoordinateOperation) = 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationSubContext_ParentNoSub" name="ParentNoSub">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2071" name="ParentNoSub">
            <language>EXPRESS_WHERE</language>
            <body>NOT('IFC4X3_ADD2.IFCGEOMETRICREPRESENTATIONSUBCONTEXT' IN TYPEOF(ParentContext))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcGeometricRepresentationSubContext_UserTargetProvided" name="UserTargetProvided">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_2072" name="UserTargetProvided">
            <language>EXPRESS_WHERE</language>
            <body>(TargetView &lt;&gt; IfcGeometricProjectionEnum.USERDEFINED) OR 
((TargetView =  IfcGeometricProjectionEnum.USERDEFINED) AND EXISTS(UserDefinedTargetView))</body>
          </specification>
        </ownedRule>
      </packagedElement>
