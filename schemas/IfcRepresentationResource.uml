          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1976" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1977" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcShapeAspect_ProductDefinitional" name="ProductDefinitional" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLogical"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1978" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1979" value="1"/>
