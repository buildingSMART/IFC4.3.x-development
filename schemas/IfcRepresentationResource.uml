        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_ParentContext" name="ParentContext" isOrdered="false" association="as_IfcGeometricRepresentationSubContext_ParentContext" type="cl_IfcGeometricRepresentationContext">
