          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2052" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2053" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcGeometricRepresentationSubContext_TargetView" name="TargetView" isOrdered="false" type="en_IfcGeometricProjectionEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_2054" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_2055" value="1"/>
