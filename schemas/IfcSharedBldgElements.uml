      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcWallStandardCase" name="IfcWallStandardCase">
        <ownedComment xmi:type="uml:Comment" xmi:id="comment_14428">
          <body>DEPRECATED</body>
        </ownedComment>
        <generalization xmi:type="uml:Generalization" xmi:id="gen_14429" general="cl_IfcWall"/>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcWallStandardCase_HasMaterialLayerSetUsage" name="HasMaterialLayerSetUsage">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_14430" name="HasMaterialLayerSetUsage">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF (QUERY(temp &lt;* USEDIN(SELF, 'IFC4X3_ADD2.IFCRELASSOCIATES.RELATEDOBJECTS') |
              ('IFC4X3_ADD2.IFCRELASSOCIATESMATERIAL' IN TYPEOF(temp)) AND
              ('IFC4X3_ADD2.IFCMATERIALLAYERSETUSAGE' IN TYPEOF(temp.RelatingMaterial))
              )) = 1</body>
          </specification>
        </ownedRule>
      </packagedElement>
