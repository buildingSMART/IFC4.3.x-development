            <language>EXPRESS_WHERE</language>
            <body>(SIZEOF(RelatingPriorities) = 0)
OR
(SIZEOF (QUERY (temp &lt;* RelatingPriorities
  | {0 &lt;= temp &lt;= 100}
  )) = SIZEOF(RelatingPriorities))</body>
          </specification>
        </ownedRule>
