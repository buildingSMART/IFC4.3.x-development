        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRelConnectsPathElements_NormalizedRelatedPriorities" name="NormalizedRelatedPriorities">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_14263" name="NormalizedRelatedPriorities">
            <language>EXPRESS_WHERE</language>
            <body>(SIZEOF(RelatedPriorities) = 0)
OR
(SIZEOF (QUERY (temp &lt;* RelatedPriorities
  | {0 &lt;= temp &lt;= 100}
  )) = SIZEOF(RelatedPriorities))</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcRelConnectsPathElements_NormalizedRelatingPriorities" name="NormalizedRelatingPriorities">
