      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcSurfaceReinforcementArea" name="IfcSurfaceReinforcementArea">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_15716" general="cl_IfcStructuralLoadOrResult"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSurfaceReinforcementArea_SurfaceReinforcement1" name="SurfaceReinforcement1_L[2:3]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_15717" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_15718" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSurfaceReinforcementArea_SurfaceReinforcement2" name="SurfaceReinforcement2_L[2:3]" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLengthMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_15719" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_15720" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcSurfaceReinforcementArea_ShearReinforcement" name="ShearReinforcement" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcRatioMeasure"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_15721" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_15722" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSurfaceReinforcementArea_NonnegativeArea1" name="NonnegativeArea1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_15723" name="NonnegativeArea1">
            <language>EXPRESS_WHERE</language>
            <body>(NOT EXISTS(SurfaceReinforcement1)) OR (
    (SurfaceReinforcement1[1] &gt;= 0.) AND
    (SurfaceReinforcement1[2] &gt;= 0.) AND
    ((SIZEOF(SurfaceReinforcement1) = 1) OR (SurfaceReinforcement1[1] &gt;= 0.))
)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSurfaceReinforcementArea_NonnegativeArea2" name="NonnegativeArea2">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_15724" name="NonnegativeArea2">
            <language>EXPRESS_WHERE</language>
            <body>(NOT EXISTS(SurfaceReinforcement2)) OR (
    (SurfaceReinforcement2[1] &gt;= 0.) AND
    (SurfaceReinforcement2[2] &gt;= 0.) AND
    ((SIZEOF(SurfaceReinforcement2) = 1) OR (SurfaceReinforcement2[1] &gt;= 0.))
)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSurfaceReinforcementArea_NonnegativeArea3" name="NonnegativeArea3">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_15725" name="NonnegativeArea3">
            <language>EXPRESS_WHERE</language>
            <body>(NOT EXISTS(ShearReinforcement)) OR (ShearReinforcement &gt;= 0.)</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcSurfaceReinforcementArea_SurfaceAndOrShearAreaSpecified" name="SurfaceAndOrShearAreaSpecified">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_15726" name="SurfaceAndOrShearAreaSpecified">
            <language>EXPRESS_WHERE</language>
            <body>EXISTS(SurfaceReinforcement1) OR EXISTS(SurfaceReinforcement2) OR EXISTS(ShearReinforcement)</body>
          </specification>
        </ownedRule>
      </packagedElement>
