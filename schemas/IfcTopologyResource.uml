<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmlns:uml="http://www.eclipse.org/uml2/5.0.0/UML" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" xmi:version="20131001">
  <uml:Model xmi:id="md_IfcTopologyResource" name="IfcTopologyResource">
    <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcTopologyResource" name="IfcTopologyResource">
      <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcBooleanChoose" name="IfcBooleanChoose">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1820" name="IfcBooleanChoose">
          <language>EXPRESS_FUNCTION</language>
          <body>FUNCTION IfcBooleanChoose
(B : BOOLEAN ;
     Choice1, Choice2 : GENERIC : Item) : GENERIC : Item;
  IF B THEN
     RETURN (Choice1);
  ELSE
     RETURN (Choice2);
  END_IF;

END_FUNCTION;
</body>
        </specification>
      </packagedElement>
      <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcLoopHeadToTail" name="IfcLoopHeadToTail">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1821" name="IfcLoopHeadToTail">
          <language>EXPRESS_FUNCTION</language>
          <body>FUNCTION IfcLoopHeadToTail
(ALoop : IfcEdgeLoop) : LOGICAL;
   LOCAL
     N : INTEGER;
     P : LOGICAL := TRUE;
   END_LOCAL;
     
     N := SIZEOF (ALoop.EdgeList);
     REPEAT i := 2 TO N;
       P := P AND (ALoop.EdgeList[i-1].EdgeEnd :=:
                   ALoop.EdgeList[i].EdgeStart);
     END_REPEAT;     
     RETURN (P);

END_FUNCTION;
</body>
        </specification>
      </packagedElement>
      <packagedElement xmi:type="uml:Constraint" xmi:id="ct_IfcPathHeadToTail" name="IfcPathHeadToTail">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1822" name="IfcPathHeadToTail">
          <language>EXPRESS_FUNCTION</language>
          <body>FUNCTION IfcPathHeadToTail
(APath : IfcPath) : LOGICAL;
   LOCAL
     N : INTEGER := 0;
     P : LOGICAL := UNKNOWN;
   END_LOCAL;
     N := SIZEOF (APath.EdgeList);
   REPEAT i := 2 TO N;
      P := P AND (APath.EdgeList[i-1].EdgeEnd :=:
                  APath.EdgeList[i].EdgeStart);
   END_REPEAT;
   RETURN (P);

END_FUNCTION;
</body>
        </specification>
      </packagedElement>
