        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:type="uml:Association" xmi:id="as_IfcEdge_EdgeEnd" name="EdgeEnd" memberEnd="at_IfcEdge_EdgeEnd end_242">
        <ownedEnd xmi:type="uml:Property" xmi:id="end_242" name="" association="as_IfcEdge_EdgeEnd" type="cl_IfcEdge">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_1903" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_1904" value="1"/>
        </ownedEnd>
      </packagedElement>
      <packagedElement xmi:type="uml:Association" xmi:id="as_IfcEdgeCurve_EdgeGeometry" name="EdgeGeometry" memberEnd="at_IfcEdgeCurve_EdgeGeometry end_244">
        <ownedEnd xmi:type="uml:Property" xmi:id="end_244" name="" association="as_IfcEdgeCurve_EdgeGeometry" type="cl_IfcEdgeCurve">
