        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcPolyLoop_AllPointsSameDim" name="AllPointsSameDim">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_1883" name="AllPointsSameDim">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY(Temp &lt;* Polygon | Temp.Dim &lt;&gt; Polygon[1].Dim)) = 0</body>
          </specification>
        </ownedRule>
