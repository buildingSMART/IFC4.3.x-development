        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTable_Rows" name="Rows_L[1:?]" isOrdered="false" association="as_IfcTable_Rows" type="cl_IfcTableRow">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11285" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11286" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTable_Columns" name="Columns_L[1:?]" isOrdered="false" association="as_IfcTable_Columns" type="cl_IfcTableColumn">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11287" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11288" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTable_NumberOfCellsInRow" name="NumberOfCellsInRow" isOrdered="false" isDerived="true">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11289" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11290" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_11291" name="NumberOfCellsInRow">
            <language>EXPRESS</language>
            <body>IfcInteger := HIINDEX(Rows[1].RowCells)</body>
          </defaultValue>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTable_NumberOfHeadings" name="NumberOfHeadings" isOrdered="false" isDerived="true">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11292" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11293" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_11294" name="NumberOfHeadings">
            <language>EXPRESS</language>
            <body>IfcInteger := SIZEOF(QUERY( Temp &lt;* Rows | Temp.IsHeading))</body>
          </defaultValue>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcTable_NumberOfDataRows" name="NumberOfDataRows" isOrdered="false" isDerived="true">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcInteger"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11295" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11296" value="1"/>
          <defaultValue xmi:type="uml:OpaqueExpression" xmi:id="expr_11297" name="NumberOfDataRows">
            <language>EXPRESS</language>
            <body>IfcInteger := SIZEOF(QUERY( Temp &lt;* Rows | NOT(Temp.IsHeading)))</body>
          </defaultValue>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTable_WR1" name="WR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_11298" name="WR1">
            <language>EXPRESS_WHERE</language>
            <body>SIZEOF(QUERY( Temp &lt;* Rows | HIINDEX(Temp.RowCells) &lt;&gt; HIINDEX(Rows[1].RowCells))) = 0</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcTable_WR2" name="WR2">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_11299" name="WR2">
            <language>EXPRESS_WHERE</language>
            <body>{ 0 &lt;= NumberOfHeadings &lt;= 1 }</body>
          </specification>
        </ownedRule>
      </packagedElement>
