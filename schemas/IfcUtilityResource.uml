        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_OwningApplication" name="OwningApplication" isOrdered="false" association="as_IfcOwnerHistory_OwningApplication" type="cl_IfcApplication">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11263" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11264" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_State" name="State" isOrdered="false" type="en_IfcStateEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11265" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11266" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_ChangeAction" name="ChangeAction" isOrdered="false" type="en_IfcChangeActionEnum">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11267" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11268" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_LastModifiedDate" name="LastModifiedDate" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcDateTimeResource.uml#dt_IfcTimeStamp"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11269" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11270" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_LastModifyingUser" name="LastModifyingUser" isOrdered="false" association="as_IfcOwnerHistory_LastModifyingUser">
          <type xmi:type="uml:Class" href="IfcActorResource.uml#cl_IfcPersonAndOrganization"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11271" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11272" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_LastModifyingApplication" name="LastModifyingApplication" isOrdered="false" association="as_IfcOwnerHistory_LastModifyingApplication" type="cl_IfcApplication">
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11273" value="0"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11274" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcOwnerHistory_CreationDate" name="CreationDate" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcDateTimeResource.uml#dt_IfcTimeStamp"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11275" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11276" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcOwnerHistory_CorrectChangeAction" name="CorrectChangeAction">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_11277" name="CorrectChangeAction">
            <language>EXPRESS_WHERE</language>
            <body>(EXISTS(LastModifiedDate)) OR
(NOT(EXISTS(LastModifiedDate)) AND NOT(EXISTS(ChangeAction))) OR
(NOT(EXISTS(LastModifiedDate)) AND EXISTS(ChangeAction) AND ((ChangeAction = IfcChangeActionEnum.NOTDEFINED) OR (ChangeAction = IfcChangeActionEnum.NOCHANGE)))</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcStateEnum" name="IfcStateEnum">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11278" name="LOCKED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11279" name="READONLY"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11280" name="READONLYLOCKED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11281" name="READWRITE"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11282" name="READWRITELOCKED"/>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcTable" name="IfcTable">
