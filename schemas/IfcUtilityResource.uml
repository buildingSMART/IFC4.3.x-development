  <uml:Model xmi:id="md_IfcUtilityResource" name="IfcUtilityResource">
    <packagedElement xmi:type="uml:Package" xmi:id="pk_IfcUtilityResource" name="IfcUtilityResource">
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcApplication" name="IfcApplication">
