          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11244" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11245" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcApplication_Version" name="Version" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11246" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11247" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcApplication_ApplicationFullName" name="ApplicationFullName" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcLabel"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11248" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11249" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="at_IfcApplication_ApplicationIdentifier" name="ApplicationIdentifier" isOrdered="false">
          <type xmi:type="uml:DataType" href="IfcMeasureResource.uml#dt_IfcIdentifier"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="lower_11250" value="1"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="upper_11251" value="1"/>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcApplication_UR1" name="UR1">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_11252" name="UR1">
            <language>EXPRESS_UNIQUE</language>
            <body>ApplicationIdentifier</body>
          </specification>
        </ownedRule>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_IfcApplication_UR2" name="UR2">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_11253" name="UR2">
            <language>EXPRESS_UNIQUE</language>
            <body>ApplicationFullName, Version</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Enumeration" xmi:id="en_IfcChangeActionEnum" name="IfcChangeActionEnum">
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11254" name="ADDED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11255" name="DELETED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11256" name="MODIFIED"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11257" name="NOCHANGE"/>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="literal_11258" name="NOTDEFINED"/>
      </packagedElement>
      <packagedElement xmi:type="uml:DataType" xmi:id="dt_IfcGloballyUniqueId" name="IfcGloballyUniqueId">
        <generalization xmi:type="uml:Generalization" xmi:id="gen_11259">
          <general xmi:type="uml:DataType" href="ifc4x3_add2.uml#dt_string"/>
        </generalization>
        <ownedRule xmi:type="uml:Constraint" xmi:id="ct_strlen" name="strlen">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="expr_11260" name="strlen">
            <language>OCL</language>
            <body>self.size() = 22</body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="cl_IfcOwnerHistory" name="IfcOwnerHistory">
